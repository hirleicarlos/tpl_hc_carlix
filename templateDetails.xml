<?xml version="1.0" encoding="utf-8"?>
<extension type="template" client="site" method="upgrade">
	<name>hc_carlix</name>
	<creationDate>2026-05-15</creationDate>
	<author>Hirlei Carlos</author>
	<authorEmail>noreply@example.com</authorEmail>
	<authorUrl>https://example.com</authorUrl>
	<copyright>Copyright (C) 2026 Hirlei Carlos. All rights reserved.</copyright>
	<license>GNU General Public License version 2 or later; see LICENSE</license>
	<version>1.2.0</version>
	<description>HC Carlix - Template Joomla 6.x leve, sem Bootstrap/jQuery, grid de 12 colunas, fontes self-hosted.</description>

	<inheritable>1</inheritable>

	<files>
		<filename>index.php</filename>
		<filename>component.php</filename>
		<filename>error.php</filename>
		<filename>offline.php</filename>
		<filename>templateDetails.xml</filename>
		<filename>joomla.asset.json</filename>
		<folder>field</folder>
		<folder>html</folder>
	</files>

	<languages>
		<language tag="pt-BR">pt-BR.tpl_hc_carlix.ini</language>
		<language tag="pt-BR">pt-BR.tpl_hc_carlix.sys.ini</language>
		<language tag="en-GB">en-GB.tpl_hc_carlix.ini</language>
		<language tag="en-GB">en-GB.tpl_hc_carlix.sys.ini</language>
	</languages>

	<media destination="templates/site/hc_carlix" folder="media">
		<folder>css</folder>
		<folder>js</folder>
		<folder>images</folder>
		<folder>fonts</folder>
	</media>

	<positions>
		<!-- TOPBAR -->
		<position>topbar</position>
		<position>topbar-1</position>
		<position>topbar-2</position>
		<position>topbar-3</position>
		<position>topbar-4</position>
		<!-- HEADER -->
		<position>header</position>
		<position>header-left</position>
		<position>header-center</position>
		<position>header-right</position>
		<position>logo</position>
		<position>menu</position>
		<position>search</position>
		<!-- NAVIGATION -->
		<position>navigation</position>
		<position>navigation-mobile</position>
		<!-- BANNER -->
		<position>banner</position>
		<!-- HERO / SHOWCASE -->
		<position>hero</position>
		<position>hero-top</position>
		<position>hero-bottom</position>
		<position>showcase</position>
		<position>showcase-a</position>
		<position>showcase-b</position>
		<!-- BREADCRUMBS -->
		<position>breadcrumb</position>
		<position>breadcrumbs</position>
		<!-- TOP -->
		<position>top-a</position>
		<position>top-b</position>
		<position>top-c</position>
		<position>top-d</position>
		<!-- MAIN -->
		<position>content-top</position>
		<position>content-bottom</position>
		<position>sidebar-left</position>
		<position>main-top</position>
		<position>main-bottom</position>
		<position>sidebar-right</position>
		<!-- UTILITY / FEATURES -->
		<position>utility-a</position>
		<position>utility-b</position>
		<position>utility-c</position>
		<position>feature-a</position>
		<position>feature-b</position>
		<position>feature-c</position>
		<position>feature-d</position>
		<!-- BOTTOM -->
		<position>bottom-a</position>
		<position>bottom-b</position>
		<position>bottom-c</position>
		<position>bottom-d</position>
		<!-- FOOTER -->
		<position>footer</position>
		<position>footer-a</position>
		<position>footer-b</position>
		<position>footer-c</position>
		<position>footer-1</position>
		<position>footer-2</position>
		<position>footer-3</position>
		<position>footer-4</position>
		<position>copyright</position>
		<!-- CREDITS -->
		<position>credits-1</position>
		<position>credits-2</position>
		<position>credits-3</position>
		<position>credits-4</position>
		<!-- MOBILE / OFFCANVAS -->
		<position>offcanvas</position>
		<position>mobile-menu</position>
		<!-- FLEX POSITIONS -->
		<position>position-1</position>
		<position>position-2</position>
		<position>position-3</position>
		<position>position-4</position>
		<position>position-5</position>
		<position>position-6</position>
		<position>position-7</position>
		<position>position-8</position>
		<position>position-9</position>
		<position>position-10</position>
		<position>position-11</position>
		<position>position-12</position>
		<position>position-13</position>
		<position>position-14</position>
		<position>position-15</position>
		<position>position-16</position>
		<position>position-17</position>
		<position>position-18</position>
		<position>position-19</position>
		<position>position-20</position>
		<!-- OUTRAS -->
		<position>debug</position>
		<position>error-403</position>
		<position>error-404</position>
	</positions>

	<config>
		<fields name="params">
			<fieldset name="general" label="TPL_HC_CARLIX_FIELDSET_GENERAL">
				<field name="logo" type="media" label="TPL_HC_CARLIX_LOGO_LABEL" description="TPL_HC_CARLIX_LOGO_DESC" />
				<field name="logoAlign" type="list" label="TPL_HC_CARLIX_LOGO_ALIGN_LABEL" description="TPL_HC_CARLIX_LOGO_ALIGN_DESC" default="start" validate="options">
					<option value="start">TPL_HC_CARLIX_ALIGN_START</option>
					<option value="center">TPL_HC_CARLIX_ALIGN_CENTER</option>
					<option value="end">TPL_HC_CARLIX_ALIGN_END</option>
				</field>
				<field name="favicon" type="media" label="TPL_HC_CARLIX_FAVICON_LABEL" description="TPL_HC_CARLIX_FAVICON_DESC" />
			</fieldset>

			<fieldset name="layout" label="TPL_HC_CARLIX_FIELDSET_LAYOUT" addfieldpath="/templates/hc_carlix/field">
				<field name="bodyBg" type="hidden" default="#ffffff" />
				<field name="textColor" type="hidden" default="#333333" />
				<field name="primaryColor" type="hidden" default="#d32f2f" />
				<field name="secondaryColor" type="hidden" default="#151515" />
				<field name="containerWidthValue" type="hidden" default="1320" />
				<field name="containerWidthUnit" type="hidden" default="px" />
				<field name="containerWidthCustom" type="hidden" />
				<field name="backToTop" type="hidden" default="0" />
				<field name="layoutManager" type="layoutmanager" label="TPL_HC_CARLIX_LAYOUT_MANAGER_LABEL" description="TPL_HC_CARLIX_LAYOUT_MANAGER_FIELD_DESC" hiddenLabel="true" hiddenDescription="true" filter="raw" />
			</fieldset>

			<fieldset name="menu" label="TPL_HC_CARLIX_FIELDSET_MENU">
				<field name="navigationType" type="list" label="TPL_HC_CARLIX_NAVIGATION_TYPE_LABEL" description="TPL_HC_CARLIX_NAVIGATION_TYPE_DESC" default="menu-offcanvas" validate="options">
					<option value="menu">TPL_HC_CARLIX_NAVIGATION_TYPE_MENU</option>
					<option value="menu-offcanvas">TPL_HC_CARLIX_NAVIGATION_TYPE_MENU_OFFCANVAS</option>
					<option value="offcanvas">TPL_HC_CARLIX_NAVIGATION_TYPE_OFFCANVAS</option>
				</field>
				<field name="menuAlign" type="list" label="TPL_HC_CARLIX_MENU_ALIGN_LABEL" description="TPL_HC_CARLIX_MENU_ALIGN_DESC" default="start" validate="options">
					<option value="start">TPL_HC_CARLIX_ALIGN_START</option>
					<option value="center">TPL_HC_CARLIX_ALIGN_CENTER</option>
					<option value="end">TPL_HC_CARLIX_ALIGN_END</option>
				</field>
				<field name="submenuMinWidth" type="text" label="TPL_HC_CARLIX_SUBMENU_MIN_WIDTH_LABEL" description="TPL_HC_CARLIX_SUBMENU_MIN_WIDTH_DESC" default="18rem" />
				<field name="menuInteraction" type="list" label="TPL_HC_CARLIX_MENU_INTERACTION_LABEL" description="TPL_HC_CARLIX_MENU_INTERACTION_DESC" default="hover" validate="options">
					<option value="hover">TPL_HC_CARLIX_MENU_INTERACTION_HOVER</option>
					<option value="click">TPL_HC_CARLIX_MENU_INTERACTION_CLICK</option>
				</field>
				<field name="submenuDirection" type="list" label="TPL_HC_CARLIX_SUBMENU_DIRECTION_LABEL" description="TPL_HC_CARLIX_SUBMENU_DIRECTION_DESC" default="start" validate="options">
					<option value="start">TPL_HC_CARLIX_ALIGN_START</option>
					<option value="end">TPL_HC_CARLIX_ALIGN_END</option>
				</field>
				<field name="submenuAnimation" type="list" label="TPL_HC_CARLIX_SUBMENU_ANIMATION_LABEL" description="TPL_HC_CARLIX_SUBMENU_ANIMATION_DESC" default="slide" validate="options">
					<option value="slide">TPL_HC_CARLIX_ANIMATION_SLIDE</option>
					<option value="fade">TPL_HC_CARLIX_ANIMATION_FADE</option>
					<option value="none">TPL_HC_CARLIX_ANIMATION_NONE</option>
				</field>
				<field name="submenuDelay" type="text" label="TPL_HC_CARLIX_SUBMENU_DELAY_LABEL" description="TPL_HC_CARLIX_SUBMENU_DELAY_DESC" default="0ms" />
				<field name="offcanvasSide" type="list" label="TPL_HC_CARLIX_OFFCANVAS_SIDE_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_SIDE_DESC" default="right" validate="options">
					<option value="right">TPL_HC_CARLIX_SIDE_RIGHT</option>
					<option value="left">TPL_HC_CARLIX_SIDE_LEFT</option>
				</field>
				<field name="offcanvasWidth" type="text" label="TPL_HC_CARLIX_OFFCANVAS_WIDTH_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_WIDTH_DESC" default="24rem" />
				<field name="offcanvasBackground" type="color" label="TPL_HC_CARLIX_OFFCANVAS_BG_LABEL" description="TPL_HC_CARLIX_FIELD_COLOR_DESC" default="#ffffff" />
				<field name="offcanvasTextColor" type="color" label="TPL_HC_CARLIX_OFFCANVAS_TEXT_LABEL" description="TPL_HC_CARLIX_FIELD_COLOR_DESC" default="#333333" />
				<field name="offcanvasOverlayOpacity" type="text" label="TPL_HC_CARLIX_OFFCANVAS_OVERLAY_OPACITY_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_OVERLAY_OPACITY_DESC" default="0.55" />
				<field name="offcanvasOverlayBlur" type="text" label="TPL_HC_CARLIX_OFFCANVAS_OVERLAY_BLUR_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_OVERLAY_BLUR_DESC" default="2px" />
				<field name="offcanvasSpeed" type="text" label="TPL_HC_CARLIX_OFFCANVAS_SPEED_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_SPEED_DESC" default="200ms" />
				<field name="offcanvasCloseOnClick" type="radio" layout="joomla.form.field.radio.switcher" label="TPL_HC_CARLIX_OFFCANVAS_CLOSE_ON_CLICK_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_CLOSE_ON_CLICK_DESC" default="1" filter="integer">
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				<field name="offcanvasShowLogo" type="radio" layout="joomla.form.field.radio.switcher" label="TPL_HC_CARLIX_OFFCANVAS_SHOW_LOGO_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_SHOW_LOGO_DESC" default="1" filter="integer">
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				<field name="offcanvasLogo" type="media" label="TPL_HC_CARLIX_OFFCANVAS_LOGO_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_LOGO_DESC" />
				<field name="offcanvasLogoAlign" type="list" label="TPL_HC_CARLIX_OFFCANVAS_LOGO_ALIGN_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_LOGO_ALIGN_DESC" default="start" validate="options">
					<option value="start">TPL_HC_CARLIX_ALIGN_START</option>
					<option value="center">TPL_HC_CARLIX_ALIGN_CENTER</option>
					<option value="end">TPL_HC_CARLIX_ALIGN_END</option>
				</field>
				<field name="offcanvasLogoHeight" type="text" label="TPL_HC_CARLIX_OFFCANVAS_LOGO_HEIGHT_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_LOGO_HEIGHT_DESC" default="2.5rem" />
				<field name="mobileButtonPosition" type="list" label="TPL_HC_CARLIX_MOBILE_BUTTON_POSITION_LABEL" description="TPL_HC_CARLIX_MOBILE_BUTTON_POSITION_DESC" default="end" validate="options">
					<option value="start">TPL_HC_CARLIX_ALIGN_START</option>
					<option value="center">TPL_HC_CARLIX_ALIGN_CENTER</option>
					<option value="end">TPL_HC_CARLIX_ALIGN_END</option>
				</field>
				<field name="mobileButtonSize" type="text" label="TPL_HC_CARLIX_MOBILE_BUTTON_SIZE_LABEL" description="TPL_HC_CARLIX_MOBILE_BUTTON_SIZE_DESC" default="2.75rem" />
				<field name="mobileButtonColor" type="color" label="TPL_HC_CARLIX_MOBILE_BUTTON_COLOR_LABEL" description="TPL_HC_CARLIX_FIELD_COLOR_DESC" default="#111111" />
				<field name="mobileButtonBackground" type="color" label="TPL_HC_CARLIX_MOBILE_BUTTON_BG_LABEL" description="TPL_HC_CARLIX_FIELD_COLOR_DESC" default="#ffffff" />
				<field name="mobileButtonBorder" type="text" label="TPL_HC_CARLIX_MOBILE_BUTTON_BORDER_LABEL" description="TPL_HC_CARLIX_MOBILE_BUTTON_BORDER_DESC" default="1px solid #e6e6e6" />
				<field name="mobileButtonRadius" type="text" label="TPL_HC_CARLIX_MOBILE_BUTTON_RADIUS_LABEL" description="TPL_HC_CARLIX_MOBILE_BUTTON_RADIUS_DESC" default="0.5rem" />
			</fieldset>

			<fieldset name="code" label="TPL_HC_CARLIX_FIELDSET_CODE">
				<field name="gaId" type="text" label="TPL_HC_CARLIX_GA_LABEL" description="TPL_HC_CARLIX_GA_DESC" filter="cmd" />
				<field name="headCode" type="textarea" label="TPL_HC_CARLIX_HEADCODE_LABEL" description="TPL_HC_CARLIX_HEADCODE_DESC" rows="6" filter="raw" />
				<field name="bodyCode" type="textarea" label="TPL_HC_CARLIX_BODYCODE_LABEL" description="TPL_HC_CARLIX_BODYCODE_DESC" rows="6" filter="raw" />
				<field name="customCss" type="textarea" label="TPL_HC_CARLIX_CUSTOMCSS_LABEL" description="TPL_HC_CARLIX_CUSTOMCSS_DESC" rows="6" filter="raw" />
			</fieldset>

			<fieldset name="seo" label="TPL_HC_CARLIX_FIELDSET_SEO">
				<field name="seoTitleSuffix" type="text" label="TPL_HC_CARLIX_SEO_TITLE_SUFFIX_LABEL" description="TPL_HC_CARLIX_SEO_TITLE_SUFFIX_DESC" />
				<field name="seoDescription" type="textarea" label="TPL_HC_CARLIX_SEO_DESCRIPTION_LABEL" description="TPL_HC_CARLIX_SEO_DESCRIPTION_DESC" rows="3" filter="string" />
				<field name="seoRobots" type="list" label="TPL_HC_CARLIX_SEO_ROBOTS_LABEL" description="TPL_HC_CARLIX_SEO_ROBOTS_DESC" default="" validate="options">
					<option value="">TPL_HC_CARLIX_SEO_ROBOTS_JOOMLA</option>
					<option value="index, follow">index, follow</option>
					<option value="noindex, follow">noindex, follow</option>
					<option value="index, nofollow">index, nofollow</option>
					<option value="noindex, nofollow">noindex, nofollow</option>
				</field>
				<field name="canonicalUrl" type="url" label="TPL_HC_CARLIX_CANONICAL_LABEL" description="TPL_HC_CARLIX_CANONICAL_DESC" filter="url" />
				<field name="ogTitle" type="text" label="TPL_HC_CARLIX_OG_TITLE_LABEL" description="TPL_HC_CARLIX_OG_TITLE_DESC" />
				<field name="ogDescription" type="textarea" label="TPL_HC_CARLIX_OG_DESCRIPTION_LABEL" description="TPL_HC_CARLIX_OG_DESCRIPTION_DESC" rows="3" filter="string" />
				<field name="ogImage" type="media" label="TPL_HC_CARLIX_OG_IMAGE_LABEL" description="TPL_HC_CARLIX_OG_IMAGE_DESC" />
				<field name="ogType" type="list" label="TPL_HC_CARLIX_OG_TYPE_LABEL" description="TPL_HC_CARLIX_OG_TYPE_DESC" default="website" validate="options">
					<option value="website">website</option>
					<option value="article">article</option>
				</field>
				<field name="twitterCard" type="list" label="TPL_HC_CARLIX_TWITTER_CARD_LABEL" description="TPL_HC_CARLIX_TWITTER_CARD_DESC" default="summary_large_image" validate="options">
					<option value="summary_large_image">summary_large_image</option>
					<option value="summary">summary</option>
				</field>
				<field name="schemaJsonLd" type="textarea" label="TPL_HC_CARLIX_SCHEMA_LABEL" description="TPL_HC_CARLIX_SCHEMA_DESC" rows="8" filter="raw" />
			</fieldset>

		</fields>
	</config>
</extension>

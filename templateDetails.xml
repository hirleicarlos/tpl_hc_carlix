				<field name="logoAlign" type="list" label="TPL_HC_CARLIX_LOGO_ALIGN_LABEL" description="TPL_HC_CARLIX_LOGO_ALIGN_DESC" default="start" validate="options">
					<option value="start">TPL_HC_CARLIX_ALIGN_START</option>
					<option value="center">TPL_HC_CARLIX_ALIGN_CENTER</option>
					<option value="end">TPL_HC_CARLIX_ALIGN_END</option>
				</field>
				<field name="textColor" type="color" label="TPL_HC_CARLIX_TEXTCOLOR_LABEL" description="TPL_HC_CARLIX_TEXTCOLOR_DESC" default="#333333" />
				<field name="primaryColor" type="color" label="TPL_HC_CARLIX_PRIMARY_COLOR_LABEL" description="TPL_HC_CARLIX_FIELD_COLOR_DESC" default="#d32f2f" />
				<field name="secondaryColor" type="color" label="TPL_HC_CARLIX_SECONDARY_COLOR_LABEL" description="TPL_HC_CARLIX_FIELD_COLOR_DESC" default="#151515" />
				<field name="containerWidth" type="text" label="TPL_HC_CARLIX_CONTAINER_WIDTH_LABEL" description="TPL_HC_CARLIX_CONTAINER_WIDTH_DESC" default="1200px" />

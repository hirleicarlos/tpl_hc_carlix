	<config>
		<fields name="params">
			<fieldset name="general" label="TPL_HC_CARLIX_FIELDSET_GENERAL">
				<field name="logoIdentityGroup" type="spacer" label="TPL_HC_CARLIX_GROUP_LOGO_IDENTITY" />
				<field name="logoType" type="list" label="TPL_HC_CARLIX_LOGO_TYPE_LABEL" description="TPL_HC_CARLIX_LOGO_TYPE_DESC" default="image" validate="options">
					<option value="image">TPL_HC_CARLIX_LOGO_TYPE_IMAGE</option>
					<option value="text">TPL_HC_CARLIX_LOGO_TYPE_TEXT</option>
				</field>
				<field name="logoText" type="text" label="TPL_HC_CARLIX_LOGO_TEXT_LABEL" description="TPL_HC_CARLIX_LOGO_TEXT_DESC" default="HC Carlix" showon="logoType:text" />
				<field name="logoSlogan" type="text" label="TPL_HC_CARLIX_LOGO_SLOGAN_LABEL" description="TPL_HC_CARLIX_LOGO_SLOGAN_DESC" default="Lightweight Joomla Template" showon="logoType:text" />
				<field name="logo" type="media" label="TPL_HC_CARLIX_LOGO_LABEL" description="TPL_HC_CARLIX_LOGO_DESC" preview="true" showon="logoType:image" />
				<field name="retinaLogo" type="media" label="TPL_HC_CARLIX_RETINA_LOGO_LABEL" description="TPL_HC_CARLIX_RETINA_LOGO_DESC" preview="true" showon="logoType:image" />
				<field name="mobileLogo" type="media" label="TPL_HC_CARLIX_MOBILE_LOGO_LABEL" description="TPL_HC_CARLIX_MOBILE_LOGO_DESC" preview="true" showon="logoType:image" />
				<field name="stickyLogo" type="media" label="TPL_HC_CARLIX_STICKY_LOGO_LABEL" description="TPL_HC_CARLIX_STICKY_LOGO_DESC" preview="true" showon="logoType:image" />
				<field name="logoAlt" type="text" label="TPL_HC_CARLIX_LOGO_ALT_LABEL" description="TPL_HC_CARLIX_LOGO_ALT_DESC" default="HC Carlix" showon="logoType:image" />
				<field name="logoWidth" type="text" label="TPL_HC_CARLIX_LOGO_WIDTH_LABEL" description="TPL_HC_CARLIX_LOGO_WIDTH_DESC" showon="logoType:image" />
				<field name="logoHeight" type="text" label="TPL_HC_CARLIX_LOGO_HEIGHT_LABEL" description="TPL_HC_CARLIX_LOGO_HEIGHT_DESC" showon="logoType:image" />
				<field name="logoAlign" type="list" label="TPL_HC_CARLIX_LOGO_ALIGN_LABEL" description="TPL_HC_CARLIX_LOGO_ALIGN_DESC" default="start" validate="options">
					<option value="start">TPL_HC_CARLIX_ALIGN_START</option>
					<option value="center">TPL_HC_CARLIX_ALIGN_CENTER</option>
					<option value="end">TPL_HC_CARLIX_ALIGN_END</option>
				</field>
				<field name="logoCustomLink" type="text" label="TPL_HC_CARLIX_LOGO_CUSTOM_LINK_LABEL" description="TPL_HC_CARLIX_LOGO_CUSTOM_LINK_DESC" default="/" />
				<field name="generalSiteGroup" type="spacer" label="TPL_HC_CARLIX_GROUP_SITE" />
				<field name="favicon" type="media" label="TPL_HC_CARLIX_FAVICON_LABEL" description="TPL_HC_CARLIX_FAVICON_DESC" preview="true" />
				<field name="appleTouchIcon" type="media" label="TPL_HC_CARLIX_APPLE_TOUCH_ICON_LABEL" description="TPL_HC_CARLIX_APPLE_TOUCH_ICON_DESC" preview="true" />
				<field name="themeColor" type="color" label="TPL_HC_CARLIX_THEME_COLOR_LABEL" description="TPL_HC_CARLIX_THEME_COLOR_DESC" default="#d32f2f" />
			</fieldset>

			<fieldset name="layout" label="TPL_HC_CARLIX_FIELDSET_LAYOUT" addfieldpath="/templates/hc_carlix/field">
				<field name="bodyBg" type="hidden" default="#ffffff" />
				<field name="textColor" type="hidden" default="#333333" />
				<field name="containerWidthValue" type="hidden" default="1320" />
				<field name="containerWidthUnit" type="hidden" default="px" />
				<field name="containerWidthCustom" type="hidden" />
				<field name="backToTop" type="hidden" default="0" />
				<field name="smoothScroll" type="hidden" default="1" />
				<field name="reduceMotion" type="hidden" default="0" />
				<field name="visibleFocus" type="hidden" default="1" />
				<field name="enhancedContrast" type="hidden" default="0" />
				<field name="layoutManager" type="layoutmanager" label="TPL_HC_CARLIX_LAYOUT_MANAGER_LABEL" description="TPL_HC_CARLIX_LAYOUT_MANAGER_FIELD_DESC" hiddenLabel="true" hiddenDescription="true" filter="raw" />
			</fieldset>

			<fieldset name="menu" label="TPL_HC_CARLIX_FIELDSET_MENU">
				<field name="navigationType" type="list" label="TPL_HC_CARLIX_NAVIGATION_TYPE_LABEL" description="TPL_HC_CARLIX_NAVIGATION_TYPE_DESC" default="menu-offcanvas" validate="options">
					<option value="menu">TPL_HC_CARLIX_NAVIGATION_TYPE_MENU</option>
					<option value="menu-offcanvas">TPL_HC_CARLIX_NAVIGATION_TYPE_MENU_OFFCANVAS</option>
					<option value="offcanvas">TPL_HC_CARLIX_NAVIGATION_TYPE_OFFCANVAS</option>
				</field>
				<field name="menuAlign" type="list" label="TPL_HC_CARLIX_MENU_ALIGN_LABEL" description="TPL_HC_CARLIX_MENU_ALIGN_DESC" default="start" validate="options">
					<option value="start">TPL_HC_CARLIX_ALIGN_START</option>
					<option value="center">TPL_HC_CARLIX_ALIGN_CENTER</option>
					<option value="end">TPL_HC_CARLIX_ALIGN_END</option>
				</field>
				<field name="submenuMinWidth" type="text" label="TPL_HC_CARLIX_SUBMENU_MIN_WIDTH_LABEL" description="TPL_HC_CARLIX_SUBMENU_MIN_WIDTH_DESC" default="18rem" />
				<field name="menuInteraction" type="list" label="TPL_HC_CARLIX_MENU_INTERACTION_LABEL" description="TPL_HC_CARLIX_MENU_INTERACTION_DESC" default="hover" validate="options">
					<option value="hover">TPL_HC_CARLIX_MENU_INTERACTION_HOVER</option>
					<option value="click">TPL_HC_CARLIX_MENU_INTERACTION_CLICK</option>
				</field>
				<field name="submenuDirection" type="list" label="TPL_HC_CARLIX_SUBMENU_DIRECTION_LABEL" description="TPL_HC_CARLIX_SUBMENU_DIRECTION_DESC" default="start" validate="options">
					<option value="start">TPL_HC_CARLIX_ALIGN_START</option>
					<option value="end">TPL_HC_CARLIX_ALIGN_END</option>
				</field>
				<field name="submenuAnimation" type="list" label="TPL_HC_CARLIX_SUBMENU_ANIMATION_LABEL" description="TPL_HC_CARLIX_SUBMENU_ANIMATION_DESC" default="slide" validate="options">
					<option value="slide">TPL_HC_CARLIX_ANIMATION_SLIDE</option>
					<option value="fade">TPL_HC_CARLIX_ANIMATION_FADE</option>
					<option value="none">TPL_HC_CARLIX_ANIMATION_NONE</option>
				</field>
				<field name="submenuDelay" type="text" label="TPL_HC_CARLIX_SUBMENU_DELAY_LABEL" description="TPL_HC_CARLIX_SUBMENU_DELAY_DESC" default="0ms" />
				<field name="offcanvasSide" type="list" label="TPL_HC_CARLIX_OFFCANVAS_SIDE_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_SIDE_DESC" default="right" validate="options">
					<option value="right">TPL_HC_CARLIX_SIDE_RIGHT</option>
					<option value="left">TPL_HC_CARLIX_SIDE_LEFT</option>
				</field>
				<field name="offcanvasWidth" type="text" label="TPL_HC_CARLIX_OFFCANVAS_WIDTH_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_WIDTH_DESC" default="24rem" />
				<field name="offcanvasBackground" type="text" label="TPL_HC_CARLIX_OFFCANVAS_BG_LABEL" description="TPL_HC_CARLIX_FIELD_COLOR_DESC" default="#ffffff" filter="raw" />
				<field name="offcanvasTextColor" type="text" label="TPL_HC_CARLIX_OFFCANVAS_TEXT_LABEL" description="TPL_HC_CARLIX_FIELD_COLOR_DESC" default="#333333" filter="raw" />
				<field name="offcanvasOverlayOpacity" type="text" label="TPL_HC_CARLIX_OFFCANVAS_OVERLAY_OPACITY_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_OVERLAY_OPACITY_DESC" default="0.55" />
				<field name="offcanvasOverlayBlur" type="text" label="TPL_HC_CARLIX_OFFCANVAS_OVERLAY_BLUR_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_OVERLAY_BLUR_DESC" default="2px" />
				<field name="offcanvasSpeed" type="text" label="TPL_HC_CARLIX_OFFCANVAS_SPEED_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_SPEED_DESC" default="200ms" />
				<field name="offcanvasCloseOnClick" type="radio" layout="joomla.form.field.radio.switcher" label="TPL_HC_CARLIX_OFFCANVAS_CLOSE_ON_CLICK_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_CLOSE_ON_CLICK_DESC" default="1" filter="integer">
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				<field name="offcanvasShowLogo" type="radio" layout="joomla.form.field.radio.switcher" label="TPL_HC_CARLIX_OFFCANVAS_SHOW_LOGO_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_SHOW_LOGO_DESC" default="1" filter="integer">
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				<field name="offcanvasLogo" type="media" label="TPL_HC_CARLIX_OFFCANVAS_LOGO_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_LOGO_DESC" />
				<field name="offcanvasLogoAlign" type="list" label="TPL_HC_CARLIX_OFFCANVAS_LOGO_ALIGN_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_LOGO_ALIGN_DESC" default="start" validate="options">
					<option value="start">TPL_HC_CARLIX_ALIGN_START</option>
					<option value="center">TPL_HC_CARLIX_ALIGN_CENTER</option>
					<option value="end">TPL_HC_CARLIX_ALIGN_END</option>
				</field>
				<field name="offcanvasLogoHeight" type="text" label="TPL_HC_CARLIX_OFFCANVAS_LOGO_HEIGHT_LABEL" description="TPL_HC_CARLIX_OFFCANVAS_LOGO_HEIGHT_DESC" default="2.5rem" />
				<field name="mobileButtonPosition" type="list" label="TPL_HC_CARLIX_MOBILE_BUTTON_POSITION_LABEL" description="TPL_HC_CARLIX_MOBILE_BUTTON_POSITION_DESC" default="end" validate="options">
					<option value="start">TPL_HC_CARLIX_ALIGN_START</option>
					<option value="end">TPL_HC_CARLIX_ALIGN_END</option>
				</field>
				<field name="mobileButtonSize" type="text" label="TPL_HC_CARLIX_MOBILE_BUTTON_SIZE_LABEL" description="TPL_HC_CARLIX_MOBILE_BUTTON_SIZE_DESC" default="2.75rem" />
				<field name="mobileButtonColor" type="text" label="TPL_HC_CARLIX_MOBILE_BUTTON_COLOR_LABEL" description="TPL_HC_CARLIX_FIELD_COLOR_DESC" default="#111111" filter="raw" />
				<field name="mobileButtonBackground" type="text" label="TPL_HC_CARLIX_MOBILE_BUTTON_BG_LABEL" description="TPL_HC_CARLIX_FIELD_COLOR_DESC" default="#ffffff" filter="raw" />
				<field name="mobileButtonBorder" type="text" label="TPL_HC_CARLIX_MOBILE_BUTTON_BORDER_LABEL" description="TPL_HC_CARLIX_MOBILE_BUTTON_BORDER_DESC" default="1px solid #e6e6e6" />

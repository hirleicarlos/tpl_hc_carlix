					<option value="sticky">TPL_HC_CARLIX_HEADER_BEHAVIOR_STICKY</option>
					<option value="fixed">TPL_HC_CARLIX_HEADER_BEHAVIOR_FIXED</option>
					<option value="floating">TPL_HC_CARLIX_HEADER_BEHAVIOR_FLOATING</option>
				</field>
				<field name="menuAlign" type="list" label="TPL_HC_CARLIX_MENU_ALIGN_LABEL" description="TPL_HC_CARLIX_MENU_ALIGN_DESC" default="start" validate="options">
					<option value="start">TPL_HC_CARLIX_ALIGN_START</option>
					<option value="center">TPL_HC_CARLIX_ALIGN_CENTER</option>
					<option value="end">TPL_HC_CARLIX_ALIGN_END</option>

# ============================================================
# HC Carlix Template - rastrear somente o pacote instalavel
# ============================================================

# Ignora tudo por padrao. O repositorio deve conter apenas o que entra
# na instalacao do template Joomla, alem deste arquivo de controle.
*

# Controle do proprio repositorio
!.gitignore
!README.md

# Arquivos raiz instalaveis
!LICENSE
!component.php
!error.php
!index.php
!joomla.asset.json
!offline.php
!templateDetails.xml

# Idiomas instalaveis
!en-GB.tpl_hc_carlix.ini
!en-GB.tpl_hc_carlix.sys.ini
!pt-BR.tpl_hc_carlix.ini
!pt-BR.tpl_hc_carlix.sys.ini

# Campos, overrides e layouts instalaveis
!field/
!field/**
!html/
!html/**

# Media instalado pelo manifest
!media/
!media/css/
!media/css/**
!media/fonts/
!media/fonts/**
!media/images/
!media/images/**
!media/js/
!media/js/**
!media/vendor/
!media/vendor/**

# Nunca versionar artefatos locais mesmo dentro de pastas liberadas
*.log
*.tmp
*.temp
*.bak
*.orig
*.rej
*.swp
*.swo
*~
*.css.map
*.js.map
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.jpa
*.jps
__pycache__/
.DS_Store
Thumbs.db
Desktop.ini
